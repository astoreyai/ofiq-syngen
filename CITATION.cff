    year: 2024
    institution:
      name: "ISO/IEC JTC 1/SC 37"
    notes: "ISO/IEC 29794-5:2024."
  - type: standard
    title: "Information technology -- Biometric data interchange formats -- Part 5: Face image data"
    year: 2011
    institution:
      name: "ISO/IEC JTC 1/SC 37"
    notes: "ISO/IEC 19794-5:2011 plus Amd 1:2014, Amd 2:2014."
  - type: standard
    title: "Machine Readable Travel Documents -- Part 9: Deployment of Biometric Identification and Electronic Storage of Data in MRTDs"
    year: 2021
    institution:
      name: "International Civil Aviation Organization"
    notes: "ICAO Doc 9303 Part 9, 8th edition."
