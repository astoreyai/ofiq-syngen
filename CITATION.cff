    authors:
      - family-names: Schlett
        given-names: Torsten
      - family-names: Damer
        given-names: Naser
    title: "OFIQ: an open-source software library for face image quality assessment"
    year: 2024
    conference:
      name: "IEEE International Joint Conference on Biometrics (IJCB)"
    notes: "Reference implementation cited for algorithm provenance. Verify exact citation at https://www.bsi.bund.de/OFIQ before publication."
  - type: standard
